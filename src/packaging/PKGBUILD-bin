# Maintainer: StressarN <martin.gustavsen@kreatell.com>
pkgname=droidproxy-linux-bin
_realname=droidproxy
pkgver=1.8.13
pkgrel=1
pkgdesc="Proxy Claude, Codex, and Gemini subscriptions for Factory Droid CLI (AppImage)"
# Only x86_64 AppImages are built by .github/workflows/linux-release.yml today.
# aarch64 users should install the source package `droidproxy-linux` instead
# (arch=('any'), pure Python). If CI starts producing aarch64 AppImages,
# re-add 'aarch64' here plus source_aarch64=/sha256sums_aarch64= lines.
arch=('x86_64')
url="https://github.com/StressarN/droidproxy-linux"
license=('MIT')
depends=('fuse2')
optdepends=(
    'cloudflared: expose the proxy to the public internet'
)
provides=('droidproxy')
conflicts=('droidproxy' 'droidproxy-linux')
# AppImages are self-contained ELF + squashfs payload. makepkg's strip/debug
# passes treat the whole file as a regular ELF and clobber the squashfs
# offset, producing an unrunnable AppImage ("This doesn't look like a
# squashfs image"). Disable those passes, plus lto, which makes no sense for
# a pre-built binary.
options=(!strip !debug !lto)
source_x86_64=("DroidProxyLinux-x86_64.AppImage::$url/releases/download/v${pkgver}/DroidProxyLinux-x86_64.AppImage")
source=(
    "droidproxy.desktop::$url/raw/main/src/packaging/droidproxy.desktop"
)
sha256sums_x86_64=('SKIP')
sha256sums=('SKIP')

package() {
    install -Dm755 "DroidProxyLinux-${CARCH}.AppImage" \
        "$pkgdir/opt/droidproxy/droidproxy.AppImage"
    install -d "$pkgdir/usr/bin"
    ln -s "/opt/droidproxy/droidproxy.AppImage" "$pkgdir/usr/bin/${_realname}"

    install -Dm644 droidproxy.desktop \
        "$pkgdir/usr/share/applications/droidproxy.desktop"
}
